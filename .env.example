# Copy this file to .env before running docker compose
BACKEND_PORT=8080
FRONTEND_PORT=5173

# Docker build base images (change to mirror-hosted images if Docker Hub route is blocked)
BUILDER_IMAGE=maven:3.9.6-eclipse-temurin-21
RUNTIME_IMAGE=eclipse-temurin:21-jre
VITE_BASE_URL=http://localhost:8080
BACKEND_IMAGE=vocalchat-backend:local
FRONTEND_IMAGE=vocalchat-frontend:local

# MySQL
MYSQL_ROOT_PASSWORD=changeme
MYSQL_DATABASE=vocalchat
MYSQL_USER=vocal
MYSQL_PASSWORD=changeme
MYSQL_PORT=3306

# Redis
REDIS_PORT=6379

# Ollama (optional)
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL_NAME=changeme

# MinIO
VC_MINIO_ROOT_USER=minioadmin
VC_MINIO_ROOT_PASSWORD=minioadmin
VC_MINIO_API_PORT=9005
VC_MINIO_CONSOLE_PORT=9006
VC_MINIO_ENDPOINT=http://minio:9000
VC_MINIO_BUCKET=vocalchat

# Application
DB_URL=jdbc:mysql://mysql:3306/vocalchat?useSSL=false&serverTimezone=UTC
DB_USERNAME=vocal
DB_PASSWORD=changeme

# Mail
MAIL_HOST=changeme
MAIL_PORT=changeme
MAIL_USERNAME=changeme
MAIL_PASSWORD=changeme

# JWT
JWT_SECRET=changeme
JWT_EXPIRATION=86400

# Qwen
QWEN_MODEL_NAME=qwen3.6-plus
QWEN_API_KEY=changeme

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# MinIO
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=changeme
MINIO_SECRET_KEY=changeme


